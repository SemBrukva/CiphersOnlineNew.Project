    "faq": [
        {
            "id": 489,
            "sort_order": 10,
            "published": true,
            "data": {
                "question": "¿Es el cifrado exacto del relato de Sherlock Holmes?",
                "answer": "No. El relato utiliza figuras dibujadas a mano y banderas para marcar finales de palabra. Esta herramienta conserva la idea visual, pero aplica una correspondencia regular a los alfabetos inglés y ruso."
            }
        },
        {
            "id": 490,
            "sort_order": 20,
            "published": true,
            "data": {
                "question": "¿Puede descifrar una imagen de bailarines?",
                "answer": "No. La herramienta convierte texto en figuras, pero no reconoce imágenes cargadas. Los mensajes creados aquí se pueden leer manualmente con la tabla de letras."
            }
        },
        {
            "id": 491,
            "sort_order": 30,
            "published": true,
            "data": {
                "question": "¿Cómo codifico un mensaje?",
                "answer": "Selecciona inglés o ruso, introduce el texto y las figuras aparecerán automáticamente. Pulsa «Descargar PNG» para guardar el mensaje completo como imagen."
            }
        },
        {
            "id": 492,
            "sort_order": 40,
            "published": true,
            "data": {
                "question": "¿Qué caracteres admite?",
                "answer": "El modo inglés admite A–Z y el ruso las 33 letras cirílicas, incluida Ё. Conserva los espacios; los números, signos, tildes, la Ñ y otros caracteres se sustituyen por signos de interrogación."
            }
        },
        {
            "id": 493,
            "sort_order": 50,
            "published": true,
            "data": {
                "question": "¿Necesito una clave?",
                "answer": "No. Cada letra siempre corresponde a la misma postura dentro del alfabeto seleccionado. Cualquiera que tenga la tabla adecuada puede leer el mensaje."
            }
        },
        {
            "id": 494,
            "sort_order": 60,
            "published": true,
            "data": {
                "question": "¿Es un cifrado seguro?",
                "answer": "No. Es una sustitución monoalfabética sencilla. Las repeticiones y la frecuencia de letras permiten resolver mensajes largos. No lo uses para contraseñas ni datos privados."
            }
        },
        {
            "id": 495,
            "sort_order": 70,
            "published": true,
            "data": {
                "question": "¿Para qué puedo utilizarlo?",
                "answer": "Es ideal para salas de escape, actividades escolares, búsquedas del tesoro, invitaciones y acertijos de Sherlock Holmes. Genera una imagen descargable, no una fuente instalable."
            }
        }
    ],
