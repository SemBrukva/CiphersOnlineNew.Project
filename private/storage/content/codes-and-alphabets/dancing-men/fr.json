    "faq": [
        {
            "id": 489,
            "sort_order": 10,
            "published": true,
            "data": {
                "question": "S’agit-il du chiffre exact de la nouvelle de Sherlock Holmes ?",
                "answer": "Non. La nouvelle utilise des silhouettes dessinées à la main et des drapeaux pour marquer les fins de mots. Cet outil conserve l’idée visuelle, mais applique une correspondance régulière aux alphabets anglais et russe."
            }
        },
        {
            "id": 490,
            "sort_order": 20,
            "published": true,
            "data": {
                "question": "L’outil peut-il décoder une image d’hommes dansants ?",
                "answer": "Non. Il transforme le texte en silhouettes, mais ne reconnaît pas les images importées. Un message créé ici peut être lu manuellement avec le tableau des lettres."
            }
        },
        {
            "id": 491,
            "sort_order": 30,
            "published": true,
            "data": {
                "question": "Comment encoder un message ?",
                "answer": "Sélectionnez l’anglais ou le russe, saisissez le texte et les silhouettes apparaissent automatiquement. Utilisez « Télécharger PNG » pour enregistrer le message complet."
            }
        },
        {
            "id": 492,
            "sort_order": 40,
            "published": true,
            "data": {
                "question": "Quels caractères sont pris en charge ?",
                "answer": "Le mode anglais accepte A–Z et le mode russe les 33 lettres cyrilliques, y compris Ё. Les espaces sont conservés ; chiffres, ponctuation, accents et autres caractères deviennent des points d’interrogation."
            }
        },
        {
            "id": 493,
            "sort_order": 50,
            "published": true,
            "data": {
                "question": "Une clé est-elle nécessaire ?",
                "answer": "Non. Dans l’alphabet sélectionné, chaque lettre correspond toujours à la même posture. Toute personne disposant du bon tableau peut lire le message."
            }
        },
        {
            "id": 494,
            "sort_order": 60,
            "published": true,
            "data": {
                "question": "Ce chiffre est-il sécurisé ?",
                "answer": "Non. Il s’agit d’une substitution monoalphabétique simple. Les répétitions et les fréquences permettent d’analyser les messages longs. Ne l’utilisez pas pour des mots de passe ou des données privées."
            }
        },
        {
            "id": 495,
            "sort_order": 70,
            "published": true,
            "data": {
                "question": "À quoi peut servir ce chiffre ?",
                "answer": "Il convient aux escape games, cours, chasses au trésor, invitations et énigmes Sherlock Holmes. Le résultat est une image téléchargeable, pas une police à installer."
            }
        }
    ],
