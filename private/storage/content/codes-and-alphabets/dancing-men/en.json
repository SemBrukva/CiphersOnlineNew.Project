    "faq": [
        {
            "id": 489,
            "sort_order": 10,
            "published": true,
            "data": {
                "question": "Is this the exact cipher from the Sherlock Holmes story?",
                "answer": "No. Arthur Conan Doyle's story uses a fixed set of hand-drawn figures for the English alphabet, with flags marking word endings. This encoder keeps the visual idea but uses a systematic arm-and-leg mapping that covers both the 26-letter English alphabet and the 33-letter Russian alphabet. Use the reference chart on this page for this tool's exact mapping."
            }
        },
        {
            "id": 490,
            "sort_order": 20,
            "published": true,
            "data": {
                "question": "Can this tool decode Dancing Men figures back to text?",
                "answer": "The current tool encodes text into figures; it does not read an uploaded image or automatically decode symbols. To decode a message created with this encoder, compare each pose with the alphabet reference chart below. Other versions of the Dancing Men alphabet may use a different pose-to-letter mapping."
            }
        },
        {
            "id": 491,
            "sort_order": 30,
            "published": true,
            "data": {
                "question": "How do I use the Dancing Men cipher encoder?",
                "answer": "Choose English or Russian in the Alphabet setting, type or paste a message, and watch the stick figures appear instantly. Spaces separate words. When the result is ready, select Download PNG to save the visual message as an image."
            }
        },
        {
            "id": 492,
            "sort_order": 40,
            "published": true,
            "data": {
                "question": "Which characters does the Dancing Men alphabet support?",
                "answer": "The English setting supports A–Z, and the Russian setting supports all 33 Cyrillic letters, including Ё. Input is case-insensitive. Spaces are preserved as word breaks; numbers, punctuation, emoji, and letters outside the selected alphabet appear as question marks."
            }
        },
        {
            "id": 493,
            "sort_order": 50,
            "published": true,
            "data": {
                "question": "Do I need a key to encode a message?",
                "answer": "No. This is a fixed substitution alphabet, so every supported letter always maps to the same pose in the selected language. Anyone with the same reference chart can read the message."
            }
        },
        {
            "id": 494,
            "sort_order": 60,
            "published": true,
            "data": {
                "question": "Is the Dancing Men cipher secure encryption?",
                "answer": "No. It is a simple monoalphabetic substitution code designed for visual puzzles and entertainment. Repeated letters keep the same symbols, so frequency analysis and pattern matching can reveal longer messages. Do not use it for passwords, private data, or real security."
            }
        },
        {
            "id": 495,
            "sort_order": 70,
            "published": true,
            "data": {
                "question": "What can I use a Dancing Men cipher message for?",
                "answer": "It works well for escape-room clues, scavenger hunts, classroom cryptography exercises, party invitations, mystery games, and Sherlock Holmes-themed puzzles. Downloadable output also makes it easy to print or share the encoded message."
            }
        }
    ],
