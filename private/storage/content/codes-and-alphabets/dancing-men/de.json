    "faq": [
        {
            "id": 489,
            "sort_order": 10,
            "published": true,
            "data": {
                "question": "Ist dies die exakte Chiffre aus der Sherlock-Holmes-Erzählung?",
                "answer": "Nein. Doyles Erzählung verwendet handgezeichnete Figuren und Fähnchen für Wortenden. Dieses Werkzeug übernimmt die visuelle Idee, nutzt aber eine regelmäßige Zuordnung für das englische und russische Alphabet."
            }
        },
        {
            "id": 490,
            "sort_order": 20,
            "published": true,
            "data": {
                "question": "Kann das Werkzeug Bilder mit tanzenden Männchen entschlüsseln?",
                "answer": "Nein. Es codiert Text als Figuren, erkennt aber keine hochgeladenen Bilder. Nachrichten aus diesem Encoder können anhand der Buchstabentabelle manuell gelesen werden."
            }
        },
        {
            "id": 491,
            "sort_order": 30,
            "published": true,
            "data": {
                "question": "Wie codiere ich eine Nachricht?",
                "answer": "Wählen Sie Englisch oder Russisch, geben Sie den Text ein und die Figuren werden sofort erzeugt. Mit „PNG herunterladen“ speichern Sie die vollständige Nachricht als Bild."
            }
        },
        {
            "id": 492,
            "sort_order": 40,
            "published": true,
            "data": {
                "question": "Welche Zeichen werden unterstützt?",
                "answer": "Der englische Modus unterstützt A–Z, der russische alle 33 kyrillischen Buchstaben einschließlich Ё. Leerzeichen bleiben erhalten; Ziffern, Satzzeichen, Umlaute und andere Zeichen werden als Fragezeichen dargestellt."
            }
        },
        {
            "id": 493,
            "sort_order": 50,
            "published": true,
            "data": {
                "question": "Brauche ich einen Schlüssel?",
                "answer": "Nein. Innerhalb des gewählten Alphabets steht jeder Buchstabe immer für dieselbe Haltung. Jeder mit der passenden Tabelle kann die Nachricht lesen."
            }
        },
        {
            "id": 494,
            "sort_order": 60,
            "published": true,
            "data": {
                "question": "Ist die Tanzende-Männchen-Chiffre sicher?",
                "answer": "Nein. Es handelt sich um eine einfache monoalphabetische Substitution. Wiederholungen und Buchstabenhäufigkeiten können längere Texte verraten. Verwenden Sie sie nicht für Passwörter oder vertrauliche Daten."
            }
        },
        {
            "id": 495,
            "sort_order": 70,
            "published": true,
            "data": {
                "question": "Wofür kann ich die Chiffre verwenden?",
                "answer": "Sie eignet sich für Escape Rooms, Unterricht, Schatzsuchen, Einladungen und Sherlock-Holmes-Rätsel. Die Ausgabe ist eine herunterladbare Grafik und keine installierbare Schriftart."
            }
        }
    ],
