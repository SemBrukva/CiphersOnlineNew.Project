    "faq": [
        {
            "id": 489,
            "sort_order": 10,
            "published": true,
            "data": {
                "question": "È il cifrario esatto del racconto di Sherlock Holmes?",
                "answer": "No. Il racconto usa figure disegnate a mano e bandierine per indicare la fine delle parole. Questo strumento conserva l’idea visiva, ma applica una corrispondenza regolare agli alfabeti inglese e russo."
            }
        },
        {
            "id": 490,
            "sort_order": 20,
            "published": true,
            "data": {
                "question": "Lo strumento può decodificare un’immagine?",
                "answer": "No. Converte il testo in figure, ma non riconosce immagini caricate. I messaggi creati qui possono essere letti manualmente con la tabella delle lettere."
            }
        },
        {
            "id": 491,
            "sort_order": 30,
            "published": true,
            "data": {
                "question": "Come si codifica un messaggio?",
                "answer": "Seleziona inglese o russo, inserisci il testo e le figure appariranno automaticamente. Premi «Scarica PNG» per salvare il messaggio completo come immagine."
            }
        },
        {
            "id": 492,
            "sort_order": 40,
            "published": true,
            "data": {
                "question": "Quali caratteri sono supportati?",
                "answer": "La modalità inglese supporta A–Z e quella russa tutte le 33 lettere cirilliche, inclusa Ё. Gli spazi restano; numeri, punteggiatura, accenti e altri caratteri diventano punti interrogativi."
            }
        },
        {
            "id": 493,
            "sort_order": 50,
            "published": true,
            "data": {
                "question": "Serve una chiave?",
                "answer": "No. Nell’alfabeto selezionato ogni lettera corrisponde sempre alla stessa posa. Chiunque abbia la tabella corretta può leggere il messaggio."
            }
        },
        {
            "id": 494,
            "sort_order": 60,
            "published": true,
            "data": {
                "question": "Il cifrario è sicuro?",
                "answer": "No. È una semplice sostituzione monoalfabetica. Ripetizioni e frequenze delle lettere possono rivelare i messaggi lunghi. Non usarlo per password o dati privati."
            }
        },
        {
            "id": 495,
            "sort_order": 70,
            "published": true,
            "data": {
                "question": "A cosa serve il cifrario?",
                "answer": "È ideale per escape room, lezioni, cacce al tesoro, inviti ed enigmi su Sherlock Holmes. Il risultato è un’immagine scaricabile, non un font installabile."
            }
        }
    ],
