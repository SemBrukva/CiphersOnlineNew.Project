    "faq": [
        {
            "id": 489,
            "sort_order": 10,
            "published": true,
            "data": {
                "question": "Bu, Sherlock Holmes öyküsündeki şifrenin aynısı mı?",
                "answer": "Hayır. Öyküde elle çizilmiş figürler ve kelime sonlarını gösteren bayraklar kullanılır. Bu araç görsel fikri korur, ancak İngilizce ve Rusça alfabeler için düzenli bir eşleme uygular."
            }
        },
        {
            "id": 490,
            "sort_order": 20,
            "published": true,
            "data": {
                "question": "Araç bir Dans Eden Adamlar görselini çözebilir mi?",
                "answer": "Hayır. Metni figürlere dönüştürür, ancak yüklenen görselleri tanımaz. Burada oluşturulan mesajlar harf tablosuyla elle okunabilir."
            }
        },
        {
            "id": 491,
            "sort_order": 30,
            "published": true,
            "data": {
                "question": "Bir mesajı nasıl kodlarım?",
                "answer": "İngilizce veya Rusçayı seçin, metni yazın ve figürlerin otomatik oluşmasını bekleyin. Mesajı görsel olarak kaydetmek için «PNG indir» düğmesini kullanın."
            }
        },
        {
            "id": 492,
            "sort_order": 40,
            "published": true,
            "data": {
                "question": "Hangi karakterler destekleniyor?",
                "answer": "İngilizce mod A–Z harflerini, Rusça mod Ё dâhil 33 Kiril harfini destekler. Boşluklar korunur; sayılar, noktalama ve Türkçeye özgü harfler soru işaretine dönüşür."
            }
        },
        {
            "id": 493,
            "sort_order": 50,
            "published": true,
            "data": {
                "question": "Anahtar gerekiyor mu?",
                "answer": "Hayır. Seçilen alfabede her harf her zaman aynı duruşa karşılık gelir. Doğru tabloya sahip olan herkes mesajı okuyabilir."
            }
        },
        {
            "id": 494,
            "sort_order": 60,
            "published": true,
            "data": {
                "question": "Şifre güvenli mi?",
                "answer": "Hayır. Bu basit bir tek alfabeli yerine koyma şifresidir. Tekrarlar ve harf sıklıkları uzun mesajları açığa çıkarabilir. Parolalar veya özel veriler için kullanmayın."
            }
        },
        {
            "id": 495,
            "sort_order": 70,
            "published": true,
            "data": {
                "question": "Bu şifre nerelerde kullanılabilir?",
                "answer": "Kaçış odaları, dersler, hazine avları, davetiyeler ve Sherlock Holmes bulmacaları için uygundur. Çıktı indirilebilir bir görseldir; kurulabilir bir yazı tipi değildir."
            }
        }
    ],
