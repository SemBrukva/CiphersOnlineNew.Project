    "faq": [
        {
            "id": 489,
            "sort_order": 10,
            "published": true,
            "data": {
                "question": "Esta é a cifra exata do conto de Sherlock Holmes?",
                "answer": "Não. O conto usa figuras desenhadas à mão e bandeiras para marcar o fim das palavras. A ferramenta mantém a ideia visual, mas aplica um mapeamento regular aos alfabetos inglês e russo."
            }
        },
        {
            "id": 490,
            "sort_order": 20,
            "published": true,
            "data": {
                "question": "A ferramenta decodifica uma imagem de homens dançantes?",
                "answer": "Não. Ela transforma texto em figuras, mas não reconhece imagens enviadas. As mensagens criadas aqui podem ser lidas manualmente com a tabela de letras."
            }
        },
        {
            "id": 491,
            "sort_order": 30,
            "published": true,
            "data": {
                "question": "Como codifico uma mensagem?",
                "answer": "Selecione inglês ou russo, digite o texto e as figuras aparecerão automaticamente. Clique em «Baixar PNG» para salvar a mensagem completa como imagem."
            }
        },
        {
            "id": 492,
            "sort_order": 40,
            "published": true,
            "data": {
                "question": "Quais caracteres são suportados?",
                "answer": "O modo inglês aceita A–Z e o russo todas as 33 letras cirílicas, incluindo Ё. Espaços são mantidos; números, pontuação, acentos, cedilha e outros caracteres viram pontos de interrogação."
            }
        },
        {
            "id": 493,
            "sort_order": 50,
            "published": true,
            "data": {
                "question": "Preciso de uma chave?",
                "answer": "Não. No alfabeto selecionado, cada letra sempre corresponde à mesma posição. Qualquer pessoa com a tabela correta pode ler a mensagem."
            }
        },
        {
            "id": 494,
            "sort_order": 60,
            "published": true,
            "data": {
                "question": "A cifra é segura?",
                "answer": "Não. Ela é uma substituição monoalfabética simples. Repetições e frequências de letras podem revelar mensagens longas. Não a use para senhas ou dados privados."
            }
        },
        {
            "id": 495,
            "sort_order": 70,
            "published": true,
            "data": {
                "question": "Para que posso usar a cifra?",
                "answer": "Ela é ótima para escape rooms, aulas, caças ao tesouro, convites e enigmas de Sherlock Holmes. O resultado é uma imagem para download, não uma fonte instalável."
            }
        }
    ],
