APP_NAME="Ciphers Online"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080
APP_TIMEZONE=UTC
APP_FORCE_HTTPS=false

# Обязательная Basic Auth для APP_ENV=dev
# DEV_BASIC_AUTH_USER=dev
# DEV_BASIC_AUTH_PASSWORD=change-me
# DEV_BASIC_AUTH_REALM="Dev Server"

# Доверенные обратные прокси (через запятую): IP, CIDR или * (доверять всем).
# В production задать явно: TRUSTED_PROXIES=10.0.0.0/8
# TRUSTED_PROXIES=

APP_MULTILANG=true
APP_LOCALE=en
APP_LANGUAGES=en,ru
USER_REGISTRATION=false
USER_VERIFICATION=false

# SQLite — локальная разработка (по умолчанию)
DB_CONNECTION=sqlite

# ID администраторов через запятую (те же пользователи из таблицы users)
ADMIN_IDS=1
# Путь к панели администратора (можно скрыть, изменив на произвольный)
ADMIN_PATH=/secret-admin

# Сессии
# В продакшне с HTTPS установить SESSION_SECURE=true
SESSION_SECURE=false
# Драйвер хранилища: file | memcached | redis
# SESSION_DRIVER=file
# TTL данных сессии в Memcached/Redis (секунды, по умолчанию 86400 = 24 ч)
# SESSION_TTL=86400
# Memcached для сессий (если SESSION_DRIVER=memcached)
# SESSION_MEMCACHED_HOST=127.0.0.1
# SESSION_MEMCACHED_PORT=11211
# Redis для сессий (если SESSION_DRIVER=redis)
# SESSION_REDIS_HOST=127.0.0.1
# SESSION_REDIS_PORT=6379
# SESSION_REDIS_PASSWORD=
# SESSION_REDIS_DB=1

# Логирование ошибок
# Если вебхук задан — ошибки отправляются туда (Slack / Discord / любой JSON-вебхук)
# Если не задан — пишутся в storage/logs/{env}-YYYY-MM-DD.log
# Уровень логирования: debug | info | notice | warning | error | critical | alert | emergency
LOG_LEVEL=warning
# Формат логов: text | json
LOG_FORMAT=text
LOG_WEBHOOK_LOCAL=
LOG_WEBHOOK_DEV=
LOG_WEBHOOK_PROD=

# Почта
# null://null — отключённая отправка, mailjet+stub://default — заглушка Mailjet
MAIL_DSN=null://null
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=ProjectSkeleton

# Кеширование
# CACHE_DRIVER=null  # null | memcache (null — кеш отключён)
# CACHE_PREFIX=app_  # префикс ключей в Memcached
# CACHE_TTL=3600     # TTL по умолчанию (секунды)
# MEMCACHE_HOST=127.0.0.1
# MEMCACHE_PORT=11211

# CORS (для API)
# Список разрешённых origin через запятую. По умолчанию используется APP_URL.
# В продакшне задать явно: CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
# CORS_ALLOWED_ORIGINS=http://127.0.0.1:8080

# HTTP-клиент
# HTTP_CLIENT_TIMEOUT=30          # таймаут ожидания ответа (секунды)
# HTTP_CLIENT_CONNECT_TIMEOUT=10  # таймаут установки соединения (секунды)
# HTTP_CLIENT_VERIFY_SSL=true     # проверять SSL-сертификат (true | false)

# Аналитика и реклама
# TRACKING_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# TRACKING_ADSENSE_CLIENT_ID=ca-pub-0000000000000000
# TRACKING_YANDEX_METRICA_ID=00000000
# TRACKING_YANDEX_METRICA_WEBVISOR=false
# TRACKING_YANDEX_RSYA_ENABLED=false

# MySQL — продакшн
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=project_local
# DB_USERNAME=root
# DB_PASSWORD=
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci
# DB_PREFIX=
# DB_STRICT_MODE=true

# ── Продакшн-чеклист ────────────────────────────────────────────────────────
# Перед выкаткой убедитесь, что в .env установлены следующие значения:
#
#   APP_ENV=production
#   APP_DEBUG=false         — скрывает stacktrace и внутренние ошибки
#   APP_FORCE_HTTPS=true    — принудительный редирект на HTTPS
#   SESSION_SECURE=true     — cookie только по HTTPS
#   SESSION_DRIVER=redis    — хранить сессии в Redis (рекомендуется в кластере)
#   CORS_ALLOWED_ORIGINS=https://yourdomain.com   — конкретный origin вместо *
#   LOG_LEVEL=warning       — не логировать debug/info в продакшне
#   ADMIN_PATH=/your-secret-path  — нестандартный путь к admin-панели
# ────────────────────────────────────────────────────────────────────────────
