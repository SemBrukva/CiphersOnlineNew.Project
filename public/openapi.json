{
    "openapi": "3.0.3",
    "info": {
        "title": "ProjectSkeleton",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8080"
        }
    ],
    "paths": {
        "/api/admin/stats": {
            "get": {
                "summary": "Статистика приложения",
                "tags": [
                    "admin"
                ],
                "responses": {
                    "200": {
                        "description": "Статистика",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "users_count": {
                                            "type": "integer"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Требуется авторизация"
                    },
                    "403": {
                        "description": "Недостаточно прав"
                    }
                },
                "operationId": "api.admin.stats",
                "security": [
                    {
                        "sessionAuth": []
                    }
                ]
            }
        },
        "/api/auth/login": {
            "post": {
                "summary": "Авторизация",
                "tags": [
                    "auth"
                ],
                "responses": {
                    "200": {
                        "description": "Авторизация успешна",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "ok": {
                                            "type": "boolean",
                                            "example": true
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Неверный email или пароль"
                    },
                    "422": {
                        "description": "Ошибки валидации"
                    },
                    "429": {
                        "description": "Превышен лимит запросов"
                    }
                },
                "operationId": "api.auth.login",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "maxLength": 255
                                    },
                                    "password": {
                                        "type": "string",
                                        "minLength": 1
                                    }
                                },
                                "required": [
                                    "email",
                                    "password"
                                ]
                            }
                        }
                    }
                }
            }
        },
        "/api/auth/register": {
            "post": {
                "summary": "Регистрация пользователя",
                "tags": [
                    "auth"
                ],
                "responses": {
                    "201": {
                        "description": "Пользователь создан"
                    },
                    "404": {
                        "description": "Регистрация отключена"
                    },
                    "422": {
                        "description": "Email уже занят или ошибки валидации"
                    },
                    "429": {
                        "description": "Превышен лимит запросов"
                    }
                },
                "operationId": "api.auth.register",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "minLength": 2,
                                        "maxLength": 100
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "maxLength": 255
                                    },
                                    "password": {
                                        "type": "string",
                                        "minLength": 8,
                                        "maxLength": 255
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "minLength": 8,
                                        "maxLength": 255
                                    },
                                    "language": {
                                        "type": "string",
                                        "minLength": 2,
                                        "maxLength": 10
                                    }
                                },
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ]
                            }
                        }
                    }
                }
            }
        },
        "/api/contact": {
            "post": {
                "summary": "Отправка контактного сообщения",
                "tags": [
                    "contact"
                ],
                "responses": {
                    "201": {
                        "description": "Сообщение сохранено",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "ok": {
                                            "type": "boolean",
                                            "example": true
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Ошибки валидации"
                    },
                    "429": {
                        "description": "Превышен лимит запросов"
                    }
                },
                "operationId": "api.contact",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "maxLength": 100
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "maxLength": 100
                                    },
                                    "message": {
                                        "type": "string",
                                        "maxLength": 10000
                                    }
                                },
                                "required": [
                                    "name",
                                    "email",
                                    "message"
                                ]
                            }
                        }
                    }
                }
            }
        },
        "/api/ping": {
            "get": {
                "summary": "Проверка доступности API",
                "tags": [
                    "system"
                ],
                "responses": {
                    "200": {
                        "description": "API доступен",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "pong": {
                                            "type": "boolean"
                                        },
                                        "time": {
                                            "type": "integer"
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "operationId": "api.ping"
            }
        },
        "/api/user/profile": {
            "get": {
                "summary": "Профиль пользователя",
                "tags": [
                    "user"
                ],
                "responses": {
                    "200": {
                        "description": "Данные профиля",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "id": {
                                            "type": "integer"
                                        },
                                        "name": {
                                            "type": "string"
                                        },
                                        "email": {
                                            "type": "string",
                                            "format": "email"
                                        },
                                        "language": {
                                            "type": "string",
                                            "nullable": true
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Требуется авторизация"
                    }
                },
                "operationId": "api.user.profile",
                "security": [
                    {
                        "sessionAuth": []
                    }
                ]
            }
        }
    },
    "components": {
        "securitySchemes": {
            "sessionAuth": {
                "type": "apiKey",
                "in": "cookie",
                "name": "PHPSESSID",
                "description": "Аутентификация через сессионную cookie."
            }
        }
    }
}
